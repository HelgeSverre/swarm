# Logging
LOG_ENABLED=true
LOG_PATH=logs
LOG_LEVEL=debug
APP_ENV=local
DEBUG=true

# Swarm Configuration
SWARM_REQUEST_TIMEOUT=600
SWARM_SUBPROCESS_TIMEOUT=300
SWARM_HEARTBEAT_INTERVAL=30
SWARM_TIMEOUT_RETRY_ENABLED=true

# Terminal Tool (disabled by default for security)
TERMINAL_ENABLED=false

# API Keys
TAVILY_API_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-nano
OPENAI_TEMPERATURE=0.7
OPENAI_REASONING_EFFORT=medium    # minimal, low, medium, high (reasoning models only)
OPENAI_VERBOSITY=medium           # low, medium, high (GPT-5 only)
